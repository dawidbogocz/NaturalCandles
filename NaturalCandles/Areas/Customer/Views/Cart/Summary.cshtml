@model NaturalCandles.Models.ViewModels.ShoppingCartVM
@using System.Globalization

@{
    var culture = new CultureInfo("pl-PL");
    var subtotal = Model.ShoppingCartList.Sum(x => x.Price * x.Count);
}

<form method="post">
    @Html.AntiForgeryToken()

    <div class="container py-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white py-4">
                <div class="row px-4 align-items-center">
                    <div class="col-6">
                        <h5 class="mb-0 text-uppercase">Checkout</h5>
                    </div>
                    <div class="col-6 text-end">
                        <a asp-action="Index" class="btn btn-outline-light btn-sm">Back to Cart</a>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="row g-4">
                    <div class="col-12 col-lg-7">
                        <h5 class="mb-3">Shipping details</h5>

                        <div class="row g-2 align-items-center mb-2">
                            <div class="col-3"><label asp-for="OrderHeader.Name" class="form-label mb-0"></label></div>
                            <div class="col-9">
                                <input asp-for="OrderHeader.Name" class="form-control" />
                                <span asp-validation-for="OrderHeader.Name" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-2 align-items-center mb-2">
                            <div class="col-3"><label asp-for="OrderHeader.PhoneNumber" class="form-label mb-0"></label></div>
                            <div class="col-9">
                                <input asp-for="OrderHeader.PhoneNumber" class="form-control" />
                                <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-2 align-items-center mb-2">
                            <div class="col-3"><label asp-for="OrderHeader.EmailAddress" class="form-label mb-0"></label></div>
                            <div class="col-9">
                                <input asp-for="OrderHeader.EmailAddress" class="form-control" />
                                <span asp-validation-for="OrderHeader.EmailAddress" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-2 align-items-center mb-2">
                            <div class="col-3"><label asp-for="OrderHeader.StreetAddress" class="form-label mb-0">Street</label></div>
                            <div class="col-9">
                                <input asp-for="OrderHeader.StreetAddress" class="form-control" />
                                <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-2 align-items-center mb-2">
                            <div class="col-3"><label asp-for="OrderHeader.City" class="form-label mb-0"></label></div>
                            <div class="col-9">
                                <input asp-for="OrderHeader.City" class="form-control" />
                                <span asp-validation-for="OrderHeader.City" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-2 align-items-center mb-2">
                            <div class="col-3"><label asp-for="OrderHeader.PostalCode" class="form-label mb-0">Postal code</label></div>
                            <div class="col-9">
                                <input asp-for="OrderHeader.PostalCode" class="form-control" placeholder="00-000" />
                                <span asp-validation-for="OrderHeader.PostalCode" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-2 align-items-center mb-4">
                            <div class="col-3"><label asp-for="OrderHeader.State" class="form-label mb-0">Region</label></div>
                            <div class="col-9">
                                <input asp-for="OrderHeader.State" class="form-control" />
                                <span asp-validation-for="OrderHeader.State" class="text-danger"></span>
                            </div>
                        </div>

                        <h5 class="mb-3">Delivery method</h5>
                        <div class="mb-3">
                            @foreach (var shipping in Model.ShippingMethodSettings)
                            {
                                <div class="form-check mb-2">
                                    <input asp-for="OrderHeader.ShippingMethod"
                                           class="form-check-input shipping-method"
                                           type="radio"
                                           value="@shipping.ShippingMethod"
                                           data-price="@shipping.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                           data-requires-point="@shipping.RequiresPickupPoint.ToString().ToLower()"
                                           id="shipping_@shipping.ShippingMethod" />
                                    <label class="form-check-label" for="shipping_@shipping.ShippingMethod">
                                        @shipping.DisplayName - @shipping.Price.ToString("c", culture)
                                    </label>
                                </div>
                            }
                            <span asp-validation-for="OrderHeader.ShippingMethod" class="text-danger"></span>
                        </div>

                        <div id="pickupPointBox" class="mb-4" style="display:none;">
                            <label asp-for="OrderHeader.DeliveryPointId" class="form-label">Pickup point / locker ID</label>
                            <input asp-for="OrderHeader.DeliveryPointId" class="form-control" />
                            <span asp-validation-for="OrderHeader.DeliveryPointId" class="text-danger"></span>

                            <label asp-for="OrderHeader.DeliveryPointName" class="form-label mt-2">Pickup point name</label>
                            <input asp-for="OrderHeader.DeliveryPointName" class="form-control" />
                            <span asp-validation-for="OrderHeader.DeliveryPointName" class="text-danger"></span>
                        </div>

                        <h5 class="mb-3">Payment method</h5>
                        <div class="mb-3">
                            @foreach (NaturalCandles.Models.Enums.PaymentMethod method in Enum.GetValues(typeof(NaturalCandles.Models.Enums.PaymentMethod)))
                            {
                                <div class="form-check mb-2">
                                    <input asp-for="OrderHeader.PaymentMethod"
                                           class="form-check-input"
                                           type="radio"
                                           value="@method"
                                           id="payment_@method" />
                                    <label class="form-check-label" for="payment_@method">
                                        @method
                                    </label>
                                </div>
                            }
                            <span asp-validation-for="OrderHeader.PaymentMethod" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 col-lg-5">
                        <h5 class="mb-3">Order summary</h5>

                        <ul class="list-group mb-3">
                            @foreach (var details in Model.ShoppingCartList)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold">@details.Product.Name</div>
                                        <small class="text-muted">Quantity: @details.Count</small>
                                    </div>
                                    <span class="text-muted">
                                        @((details.Price * details.Count).ToString("c", culture))
                                    </span>
                                </li>
                            }

                            <li class="list-group-item d-flex justify-content-between">
                                <small class="text-muted">Products</small>
                                <span>@subtotal.ToString("c", culture)</span>
                            </li>

                            <li class="list-group-item d-flex justify-content-between">
                                <small class="text-muted">Delivery</small>
                                <span id="deliveryPriceLabel">@Model.OrderHeader.DeliveryPrice.ToString("c", culture)</span>
                            </li>

                            <li class="list-group-item d-flex justify-content-between bg-light">
                                <strong>Total</strong>
                                <strong id="grandTotalLabel">@Model.OrderHeader.OrderTotal.ToString("c", culture)</strong>
                            </li>
                        </ul>

                        <button type="submit" class="btn btn-dark w-100 py-2">
                            Place order
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const shippingInputs = document.querySelectorAll(".shipping-method");
            const pickupPointBox = document.getElementById("pickupPointBox");
            const deliveryPriceLabel = document.getElementById("deliveryPriceLabel");
            const grandTotalLabel = document.getElementById("grandTotalLabel");
            const subtotal = @subtotal.ToString(System.Globalization.CultureInfo.InvariantCulture);

            function formatPln(value) {
                return new Intl.NumberFormat("pl-PL", {
                    style: "currency",
                    currency: "PLN"
                }).format(value);
            }

            function updateUi() {
                const selected = document.querySelector(".shipping-method:checked");
                const deliveryPrice = selected ? parseFloat(selected.dataset.price) : 0;
                const requiresPoint = selected ? selected.dataset.requiresPoint === "true" : false;

                pickupPointBox.style.display = requiresPoint ? "block" : "none";
                deliveryPriceLabel.textContent = formatPln(deliveryPrice);
                grandTotalLabel.textContent = formatPln(Number(subtotal) + deliveryPrice);
            }

            shippingInputs.forEach(x => x.addEventListener("change", updateUi));
            updateUi();
        })();
    </script>
}