@model ShoppingCartVM
@using System.Globalization

@{
    var culture = new CultureInfo("pl-PL");
}

<br />
<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white py-4">
        <div class="row px-4 align-items-center">
            <div class="col-6">
                <h5 class="mb-0 text-uppercase">Shopping Cart</h5>
            </div>
        </div>
    </div>

    <div class="card-body my-4">
        <div class="row mb-3 pb-3">
            <div class="col-md-3 offset-md-1">
                <a asp-area="Customer" asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-dark text-uppercase mb-3 btn-sm w-100">
                    <small>Continue Shopping</small>
                </a>
            </div>

            <div class="col-md-10 offset-md-1">
                @if (!Model.ShoppingCartList.Any())
                {
                    <div class="alert alert-light border text-center mb-0">
                        Your cart is empty.
                    </div>
                }
                else
                {
                    @foreach (var item in Model.ShoppingCartList)
                    {
                        <div class="row border-bottom py-3 align-items-center">
                            <div class="d-none d-lg-block col-lg-1 text-center">
                                <img src="@item.Product.ImageUrl" class="rounded" width="100%" alt="@item.Product.Name" />
                            </div>

                            <div class="col-12 col-lg-5">
                                <h6 class="text-uppercase mb-1"><strong>@item.Product.Name</strong></h6>
                                <p class="mb-0 text-muted"><small>@Html.Raw(item.Product.Description)</small></p>
                            </div>

                            <div class="col-12 col-lg-2 pt-2 text-center">
                                <div class="fw-semibold">@item.Price.ToString("c", culture)</div>
                                <div class="text-muted small">per item</div>
                            </div>

                            <div class="col-12 col-lg-2 pt-2 text-center">
                                <div class="fw-semibold">@item.Count</div>
                                <div class="text-muted small">quantity</div>
                            </div>

                            <div class="col-12 col-lg-2 mt-3 mt-lg-0">
                                <div class="d-grid gap-2">
                                    <form asp-action="Plus" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartId" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-secondary w-100">+</button>
                                    </form>

                                    <form asp-action="Minus" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartId" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-secondary w-100">-</button>
                                    </form>

                                    <form asp-action="Remove" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartId" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-danger w-100">Remove</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        @if (Model.ShoppingCartList.Any())
        {
            <div class="border-top pt-4">
                <div class="row">
                    <div class="col-md-6 offset-md-3">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="text-uppercase fw-semibold">Total (PLN)</div>
                            <div class="fs-4 fw-bolder">
                                @Model.OrderHeader.OrderTotal.ToString("c", culture)
                            </div>
                        </div>

                        <a asp-action="Summary" class="btn btn-dark w-100 py-2">
                            Summary
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>