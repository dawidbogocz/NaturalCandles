@model ShoppingCartVM

<form method="post">
    <br />
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-4">
            <div class="row px-4 align-items-center">
                <div class="col-6">
                    <h5 class="mb-0 text-uppercase">Shopping Cart</h5>
                </div>
            </div>
        </div>

        <div class="card-body my-4">
            <div class="row mb-3 pb-3">
                <div class="col-md-3 offset-md-1">
                    <a asp-area="Customer" asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-dark text-uppercase mb-3 btn-sm w-100">
                        <small>Continue Shopping</small>
                    </a>
                </div>

                <div class="col-md-10 offset-md-1">
                    @foreach (var item in Model.ShoppingCartList)
                    {
                        <div class="row border-bottom py-3 align-items-center">
                            <div class="d-none d-lg-block col-lg-1 text-center">
                                <img src="@item.Product.ImageUrl" class="rounded" width="100%" />
                            </div>

                            <div class="col-12 col-lg-6">
                                <h6 class="text-uppercase mb-1"><strong>@item.Product.Name</strong></h6>
                                <p class="mb-0 text-muted"><small>@Html.Raw(item.Product.Description)</small></p>
                            </div>

                            <div class="col-12 col-lg-5 text-center row mt-3 mt-lg-0">
                                <div class="col-12 col-md-4 pt-2">
                                    <div class="fw-semibold">
                                        @item.Price.ToString("c", new System.Globalization.CultureInfo("pl-PL"))
                                        <span class="text-muted">&nbsp;x&nbsp;</span>@item.Count
                                    </div>
                                </div>

                                <div class="col-8 col-md-5 pt-2">
                                    <div class="btn-group w-100" role="group">
                                        <a asp-action="plus" asp-route-cartId="@item.Id" class="btn btn-outline-dark">
                                            <i class="bi bi-plus-square"></i>
                                        </a>
                                        <a asp-action="minus" asp-route-cartId="@item.Id" class="btn btn-outline-dark">
                                            <i class="bi bi-dash-square"></i>
                                        </a>
                                    </div>
                                </div>

                                <div class="col-4 col-md-3 pt-2">
                                    <a asp-action="remove" asp-route-cartId="@item.Id" class="btn btn-danger w-100">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="border-top pt-4">
                <div class="row">
                    <div class="col-md-6 offset-md-3">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="text-uppercase fw-semibold">Total (PLN)</div>
                            <div class="fs-4 fw-bolder">@Model.OrderHeader.OrderTotal.ToString("c", new System.Globalization.CultureInfo("pl-PL"))</div>
                        </div>

                        <a asp-action="Summary" class="btn btn-dark w-100 py-2">
                            Summary
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</form>
