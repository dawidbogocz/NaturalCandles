@model ShoppingCart
@using System.Globalization

@{
    var culture = new CultureInfo("pl-PL");
    var tiers = (Model.Product.PriceTiers?.Any() == true
        ? Model.Product.PriceTiers.OrderBy(x => x.MinQuantity).ToList()
        : new List<ProductPriceTier>
        {
            new() { MinQuantity = 1, Price = Model.Product.BasePrice },
            new() { MinQuantity = 4, Price = Model.Product.Price4 },
            new() { MinQuantity = 10, Price = Model.Product.Price10 }
        });
}

<form method="post">
    @Html.AntiForgeryToken()
    <input hidden asp-for="ProductId" />

    <div class="card shadow-sm border-0 mt-4 mb-4">
        <div class="card-header bg-dark text-white py-4">
            <div class="text-center">
                <h3 class="text-uppercase mb-1">@Model.Product.Name</h3>
                <div class="text-white-50">@Model.Product.CategoryName</div>
            </div>
        </div>

        <div class="card-body">
            <div class="row g-4 align-items-start">
                <div class="col-12 col-lg-4">
                    <a asp-action="Index" class="btn btn-outline-dark btn-sm text-uppercase mb-3">
                        <small>Back to home</small>
                    </a>

                    <img src="@Model.Product.ImageUrl" class="img-fluid rounded" alt="@Model.Product.Name" />
                </div>

                <div class="col-12 col-lg-8">
                    <div class="mb-3">
                        <span class="badge bg-secondary">@Model.Product.CategoryName</span>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table table-sm align-middle text-center mb-0">
                            <thead>
                                <tr class="text-muted">
                                    <th>Starts at quantity</th>
                                    <th>Unit price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tier in tiers)
                                {
                                    <tr class="fw-semibold">
                                        <td>@tier.MinQuantity+</td>
                                        <td>@tier.Price.ToString("c", culture)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mb-3">
                        <p class="text-secondary lh-lg">@Html.Raw(Model.Product.Description)</p>
                    </div>

                    <div class="row g-3 align-items-center mb-3">
                        <div class="col-12 col-md-5">
                            <div class="input-group">
                                <span class="input-group-text bg-dark text-white border-0 fw-semibold">Count</span>
                                <input asp-for="Count" type="number" value="1" min="1" class="form-control text-end" />
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 py-2 text-uppercase fw-semibold">
                        Add to cart
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>