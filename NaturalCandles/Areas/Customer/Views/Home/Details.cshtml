@model ShoppingCart

<form method="post">
    <input hidden asp-for="ProductId" />

    <div class="card shadow-sm border-0 mt-4 mb-4">
        <div class="card-header bg-dark text-white py-4">
            <div class="text-center">
                <h3 class="text-uppercase mb-1">@Model.Product.Name</h3>
                <div class="text-white-50">@Model.Product.Category</div>
            </div>
        </div>

        <div class="card-body">
            <div class="row g-4 align-items-start">
                <div class="col-12 col-lg-4">
                    <a asp-action="Index" class="btn btn-outline-dark btn-sm text-uppercase mb-3">
                        <small>Back to home</small>
                    </a>

                    <img src="@Model.Product.ImageUrl" class="img-fluid rounded" alt="@Model.Product.Name" />
                </div>

                <div class="col-12 col-lg-8">
                    <div class="mb-3">
                        <span class="badge badge-category">@Model.Product.CategoryName</span>
                    </div>

                    <div class="text-muted mb-2">
                        List price:
                        <span class="text-decoration-line-through">
                            @Model.Product.BasePrice.ToString("c", new System.Globalization.CultureInfo("pl-PL"))
                        </span>
                    </div>

                    <div class="table-responsive mb-3">
                        <table class="table table-sm align-middle text-center mb-0">
                            <thead>
                                <tr class="text-muted">
                                    <th>Quantity</th>
                                    <th>1–3</th>
                                    <th>4–9</th>
                                    <th>10+</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="fw-semibold">
                                    <td>Price</td>
                                    <td>@Model.Product.BasePrice.ToString("c", new System.Globalization.CultureInfo("pl-PL"))</td>
                                    <td>@Model.Product.Price4.ToString("c", new System.Globalization.CultureInfo("pl-PL"))</td>
                                    <td>@Model.Product.Price10.ToString("c", new System.Globalization.CultureInfo("pl-PL"))</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mb-3">
                        <p class="text-secondary lh-sm">@Html.Raw(Model.Product.Description)</p>
                    </div>

                    <div class="row g-3 align-items-center mb-3">
                        <div class="col-12 col-md-5">
                            <div class="input-group">
                                <span class="input-group-text bg-dark text-white border-0 fw-semibold">
                                    Count
                                </span>
                                <input asp-for="Count"
                                       type="number"
                                       value="1"
                                       min="1"
                                       class="form-control text-end" />
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 py-2 text-uppercase fw-semibold">
                        Add to Cart
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>
