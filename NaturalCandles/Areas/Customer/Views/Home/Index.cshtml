@model IEnumerable<Product>

<div class="row g-4 pb-3">
    @foreach (var product in Model)
    {
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card h-100 shadow-sm">
                <img src="@product.ImageUrl" class="card-img-top product-card-img" alt="@product.Name" />

                <div class="card-body d-flex flex-column">
                    <h6 class="card-title text-uppercase text-center mb-3">@product.Name</h6>

                    <div class="text-center small text-muted mb-2">
                        Base price:
                        <span class="text-decoration-line-through">
                            @product.BasePrice.ToString("c", new System.Globalization.CultureInfo("pl-PL"))
                        </span>
                    </div>

                    <div class="text-center small text-muted mb-1">
                        For 4+:
                        <span class="text-decoration-line-through">
                            @product.Price4.ToString("c", new System.Globalization.CultureInfo("pl-PL"))
                        </span>
                    </div>

                    <div class="text-center fw-semibold mb-3">
                        For 10+:
                        <span>
                            @product.Price10.ToString("c", new System.Globalization.CultureInfo("pl-PL"))
                        </span>
                    </div>

                    <a asp-action="Details"
                       asp-route-productId="@product.ProductId"
                       class="btn btn-dark mt-auto w-100">
                        Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>
