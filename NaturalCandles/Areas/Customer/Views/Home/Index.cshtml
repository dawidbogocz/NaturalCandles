@model IEnumerable<Product>
@using System.Globalization
@using System.Text.Json

@{
    var culture = new CultureInfo("pl-PL");
    var products = Model.ToList();

    string BuildTierJson(Product p)
    {
        var tiers = (p.PriceTiers?.Any() == true
            ? p.PriceTiers.OrderBy(x => x.MinQuantity)
                .Select(x => new { minQuantity = x.MinQuantity, price = x.Price })
                .ToList()
            : new[]
            {
                new { minQuantity = 1, price = p.BasePrice },
                new { minQuantity = 4, price = p.Price4 },
                new { minQuantity = 10, price = p.Price10 }
            }.ToList());

        return JsonSerializer.Serialize(tiers);
    }
}

<div class="container py-4">
    <div class="row mb-4 g-3">
        <div class="col-md-8">
            <input id="productSearch" class="form-control form-control-lg" placeholder="Search products..." />
        </div>
        <div class="col-md-4">
            <select id="categoryFilter" class="form-select form-select-lg">
                <option value="">All categories</option>
                @foreach (var category in products.Select(x => x.CategoryName).Distinct().OrderBy(x => x))
                {
                    <option value="@category">@category</option>
                }
            </select>
        </div>
    </div>

    <div class="row g-4" id="productGrid">
        @foreach (var product in products)
        {
            var firstPrice = product.PriceTiers?.OrderBy(x => x.MinQuantity).FirstOrDefault()?.Price ?? product.BasePrice;

            <div class="col-12 col-md-6 col-xl-4 product-col"
                 data-search="@($"{product.Name} {product.CategoryName} {product.Description}".ToLower())"
                 data-category="@product.CategoryName">

                <div class="product-hover-card shadow-sm"
                     tabindex="0"
                     data-product-id="@product.ProductId"
                     data-tiers='@Html.Raw(BuildTierJson(product))'>

                    <div class="product-image-wrap">
                        <img src="@product.ImageUrl"
                             alt="@product.Name"
                             class="product-image" />

                        <div class="product-badge-wrap">
                            @if (product.AvailableNow)
                            {
                                <span class="badge bg-success">Available now</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Made to order</span>
                            }
                        </div>
                    </div>

                    <div class="product-summary p-3">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <h4 class="product-title mb-1">@product.Name</h4>
                                <div class="text-muted">@product.CategoryName</div>
                            </div>

                            <div class="text-end">
                                <div class="small text-muted">From</div>
                                <div class="fw-bold fs-5">@firstPrice.ToString("c", culture)</div>
                            </div>
                        </div>
                    </div>

                    <div class="product-expanded px-3 pb-3">
                        <hr class="mt-0 mb-3" />

                        <div class="product-description mb-3">
                            @Html.Raw(product.Description)
                        </div>

                        <div class="pricing-box mb-3">
                            <div class="fw-semibold mb-2">Pricing tiers</div>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered align-middle text-center mb-0">
                                    <thead>
                                        <tr>
                                            <th>Qty</th>
                                            <th>Unit price</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (product.PriceTiers != null && product.PriceTiers.Any())
                                        {
                                            @foreach (var tier in product.PriceTiers.OrderBy(x => x.MinQuantity))
                                            {
                                                <tr>
                                                    <td>@tier.MinQuantity+</td>
                                                    <td>@tier.Price.ToString("c", culture)</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td>1+</td>
                                                <td>@product.BasePrice.ToString("c", culture)</td>
                                            </tr>
                                            <tr>
                                                <td>4+</td>
                                                <td>@product.Price4.ToString("c", culture)</td>
                                            </tr>
                                            <tr>
                                                <td>10+</td>
                                                <td>@product.Price10.ToString("c", culture)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-action="QuickAdd" method="post" class="quick-add-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ProductId" value="@product.ProductId" />

                                <div class="row g-2 mb-3">
                                    <div class="col-4">
                                        <label class="form-label small fw-semibold">Qty</label>
                                        <input type="number"
                                               name="Count"
                                               value="1"
                                               min="1"
                                               class="form-control"
                                               data-role="qty" />
                                    </div>
                                    <div class="col-4">
                                        <label class="form-label small fw-semibold">Unit</label>
                                        <input type="text"
                                               class="form-control price-readonly"
                                               data-role="unitPrice"
                                               readonly />
                                    </div>
                                    <div class="col-4">
                                        <label class="form-label small fw-semibold">Total</label>
                                        <input type="text"
                                               class="form-control price-readonly"
                                               data-role="lineTotal"
                                               readonly />
                                    </div>
                                </div>

                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-dark">
                                        Add to cart
                                    </button>
                                    <a asp-action="Details"
                                           asp-route-productId="@product.ProductId"
                                           class="btn btn-outline-dark">
                                        Open details page
                                    </a>
                                </div>
                            </form>
                        }
                        else
                        {
                            <div class="d-grid">
                                <a asp-action="Details"
                                       asp-route-productId="@product.ProductId"
                                       class="btn btn-dark">
                                    View details
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .product-col {
        position: relative;
    }

    .product-hover-card {
        position: relative;
        z-index: 1;
        border-radius: 1rem;
        background: #fff;
        border: 1px solid #e9ecef;
        overflow: visible;
        transition: transform 0.22s ease, box-shadow 0.22s ease, z-index 0.22s ease;
    }

        .product-hover-card.active {
            z-index: 50;
            transform: translateY(-6px);
            box-shadow: 0 1rem 2rem rgba(0,0,0,.16) !important;
        }

    .product-image-wrap {
        position: relative;
    }

    .product-image {
        width: 100%;
        height: 260px;
        object-fit: cover;
        display: block;
        border-top-left-radius: 1rem;
        border-top-right-radius: 1rem;
    }

    .product-badge-wrap {
        position: absolute;
        top: 1rem;
        right: 1rem;
    }

    .product-summary {
        min-height: 110px;
    }

    .product-title {
        font-size: 1.2rem;
        font-weight: 700;
    }

    .product-expanded {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        transform: translateY(-8px);
        transition: max-height 0.32s ease, opacity 0.22s ease, transform 0.22s ease;
    }

    .product-hover-card.active .product-expanded {
        max-height: 900px;
        opacity: 1;
        transform: translateY(0);
    }

    .product-description {
        font-size: 0.98rem;
        line-height: 1.6;
        color: #555;
    }

    .pricing-box {
        background: #fafafa;
        border: 1px solid #ececec;
        border-radius: .75rem;
        padding: 1rem;
    }

    .price-readonly {
        background-color: #f8f9fa;
        font-weight: 600;
    }

    @@media (max-width: 991.98px) {
        .product-hover-card {
            transform: none !important;
        }

        .product-expanded {
            max-height: none !important;
            opacity: 1 !important;
            overflow: visible;
            transform: none !important;
        }
    }
</style>

@section Scripts {
    <script>
        (function () {
            const cards = Array.from(document.querySelectorAll(".product-hover-card"));
            const searchInput = document.getElementById("productSearch");
            const categoryFilter = document.getElementById("categoryFilter");
            const culture = "pl-PL";

            function formatPln(value) {
                return new Intl.NumberFormat(culture, {
                    style: "currency",
                    currency: "PLN"
                }).format(Number(value || 0));
            }

            function getUnitPrice(tiers, qty) {
                const ordered = [...tiers].sort((a, b) => a.minQuantity - b.minQuantity);
                let result = ordered[0]?.price ?? 0;

                for (const tier of ordered) {
                    if (qty >= tier.minQuantity) {
                        result = tier.price;
                    }
                }

                return Number(result);
            }

            function refreshCardPricing(card) {
                const tiers = JSON.parse(card.dataset.tiers);
                const qtyInput = card.querySelector('[data-role="qty"]');
                const unitField = card.querySelector('[data-role="unitPrice"]');
                const totalField = card.querySelector('[data-role="lineTotal"]');

                if (!qtyInput || !unitField || !totalField) return;

                let qty = parseInt(qtyInput.value || "1", 10);
                if (isNaN(qty) || qty < 1) qty = 1;
                qtyInput.value = qty;

                const unitPrice = getUnitPrice(tiers, qty);
                unitField.value = formatPln(unitPrice);
                totalField.value = formatPln(unitPrice * qty);
            }

            function closeAllCards(except = null) {
                cards.forEach(card => {
                    if (card !== except) {
                        card.classList.remove("active");
                    }
                });
            }

            function openCard(card) {
                if (window.innerWidth <= 991) return;
                closeAllCards(card);
                card.classList.add("active");
            }

            function setupPricing() {
                cards.forEach(card => {
                    refreshCardPricing(card);

                    const qtyInput = card.querySelector('[data-role="qty"]');
                    if (qtyInput) {
                        qtyInput.addEventListener("input", function () {
                            refreshCardPricing(card);
                        });
                    }
                });
            }

            function setupHoverBehavior() {
                cards.forEach(card => {
                    card.addEventListener("mouseenter", () => openCard(card));
                    card.addEventListener("focusin", () => openCard(card));

                    card.addEventListener("mouseleave", () => {
                        if (window.innerWidth <= 991) return;
                        card.classList.remove("active");
                    });

                    card.addEventListener("focusout", (e) => {
                        if (window.innerWidth <= 991) return;

                        const next = e.relatedTarget;
                        if (!next || !card.contains(next)) {
                            card.classList.remove("active");
                        }
                    });
                });

                document.addEventListener("mousemove", function (e) {
                    if (window.innerWidth <= 991) return;

                    const hoveredCard = e.target.closest(".product-hover-card");
                    if (!hoveredCard) {
                        closeAllCards();
                    }
                });
            }

            function applyFilters() {
                const search = (searchInput?.value || "").toLowerCase().trim();
                const category = categoryFilter?.value || "";

                document.querySelectorAll(".product-col").forEach(col => {
                    const matchesSearch = !search || col.dataset.search.includes(search);
                    const matchesCategory = !category || col.dataset.category === category;
                    col.style.display = (matchesSearch && matchesCategory) ? "" : "none";
                });

                closeAllCards();
            }

            cards.forEach(card => {
                const qtyInput = card.querySelector('[data-role="qty"]');
                if (qtyInput) {
                    qtyInput.addEventListener("mouseenter", e => e.stopPropagation());
                    qtyInput.addEventListener("click", e => e.stopPropagation());
                }
            });

            if (searchInput) {
                searchInput.addEventListener("input", applyFilters);
            }

            if (categoryFilter) {
                categoryFilter.addEventListener("change", applyFilters);
            }

            window.addEventListener("resize", () => {
                if (window.innerWidth <= 991) {
                    closeAllCards();
                }
            });

            setupPricing();
            setupHoverBehavior();
        })();
    </script>
}