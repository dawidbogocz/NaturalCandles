@model NaturalCandles.Models.ViewModels.EditUserRoleVM

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Change User Role</h4>
        </div>
        <div class="card-body">
            <form method="post">
                @Html.AntiForgeryToken()
                <input asp-for="UserId" type="hidden" />

                <div class="mb-3">
                    <label class="form-label">Full name</label>
                    <input class="form-control" value="@Model.FullName" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input class="form-control" value="@Model.Email" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label">Current role</label>
                    <input class="form-control" value="@Model.CurrentRole" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="NewRole" class="form-label">New role</label>
                    <select asp-for="NewRole" asp-items="Model.RoleList" class="form-select">
                        <option value="">-- select role --</option>
                    </select>
                    <span asp-validation-for="NewRole" class="text-danger"></span>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}